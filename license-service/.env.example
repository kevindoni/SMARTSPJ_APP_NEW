# SmartSPJ License Service - Vercel Environment Variables

# Neon Postgres (auto-created when you add Neon in Vercel Storage tab)
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb (auto-set by Vercel)

# Midtrans (https://dashboard.midtrans.com)
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=REPLACE_WITH_YOUR_SERVER_KEY
MIDTRANS_CLIENT_KEY=REPLACE_WITH_YOUR_CLIENT_KEY

# License Ed25519 Private Key (full PEM, single line with \n)
LICENSE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_YOUR_KEY\n-----END PRIVATE KEY-----"

# Pricing
PRICE_BASIC=100000
PRICE_PRO=200000
PRICE_LIFETIME=500000
